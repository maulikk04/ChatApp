<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
    <link rel="stylesheet" href="style.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }
    
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: #1abc9c;
            color: white;
            padding: 20px 0;
            text-align: center;
        }
    
        header nav {
            display: flex;
            justify-content: center;
        }
    
        header a {
            color: #ffffff;
            text-decoration: none;
            text-transform: uppercase;
            font-size: 16px;
            margin: 0 20px;
        }
    
        header a:hover {
            color: #e8491d;
        }
    
        .content {
            margin-top: 80px; /* Adjust this margin to leave space for the fixed header */
        }
    
        .login-container {
            background-color: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            width: 300px;
            text-align: center;
        }
    
        .login-container h2 {
            margin-bottom: 20px;
            color: #333;
        }
    
        .signup-link {
            margin-top: 10px;
            color: #007bff;
            text-decoration: none;
            display: inline-block;
        }
    
        .signup-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <nav>
                <a href="/">Home</a>
                <% if(user){ %>
                    <a href="/auth/logout">Logout</a>
                <% } else { %>
                    <a href="/auth/login">Login</a>
                <% } %>
                <a href="/chat">Chat</a>
            </nav>
        </div>
    </header>
    <div class="login-container">
        <h2>Login</h2>
        <a href="/auth/google" class="signup-link">Login with Google</a>
    </div>
</body>
</html>
